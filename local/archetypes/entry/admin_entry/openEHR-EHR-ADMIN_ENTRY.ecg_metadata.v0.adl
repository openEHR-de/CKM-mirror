definition
	ADMIN_ENTRY[at0000] matches {    -- ECG Metadata
		data matches {
			ITEM_TREE[at0001] matches {    -- Item tree
				items cardinality matches {0..*; unordered} matches {
					ELEMENT[at0007] occurrences matches {0..1} matches {    -- Study uid
						value matches {
							DV_TEXT matches {*}
						}
					}
					ELEMENT[at0011] occurrences matches {0..1} matches {    -- S3 key
						value matches {
							DV_TEXT matches {*}
						}
					}
					ELEMENT[at0017] occurrences matches {0..1} matches {    -- Date processed
						value matches {
							DV_DATE_TIME matches {*}
						}
					}
					allow_archetype CLUSTER[at0015] occurrences matches {0..*} matches {    -- Location
						include
							archetype_id/value matches {/openEHR-EHR-CLUSTER\.location\.v1|openEHR-EHR-CLUSTER\.organization\.v0/}
					}
					allow_archetype CLUSTER[at0016] occurrences matches {0..*} matches {    -- Media data
						include
							archetype_id/value matches {/openEHR-EHR-CLUSTER\.media_file\.v1/}
					}
				}
			}
		}
	}


